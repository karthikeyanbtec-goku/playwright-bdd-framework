{
    "mappings": [
        {
            "pattern": "src/pages/login.page.ts",
            "tags": "@login"
        },
        {
            "pattern": "src/steps/login.steps.ts",
            "tags": "@login"
        },
        {
            "pattern": "src/pages/inventory.page.ts",
            "tags": "@inventory"
        },
        {
            "pattern": "src/steps/inventory.steps.ts",
            "tags": "@inventory"
        },
        {
            "pattern": "src/pages/checkout.page.ts",
            "tags": "@checkout"
        },
        {
            "pattern": "src/steps/checkout.steps.ts",
            "tags": "@checkout"
        },
        {
            "pattern": "src/features/cart.feature",
            "tags": "@cart"
        },
        {
            "pattern": "src/features/about.feature",
            "tags": "@about"
        },
        {
            "pattern": "src/steps/cart_about.steps.ts",
            "tags": "@cart or @about"
        },
        {
            "pattern": "src/utils/**/*",
            "tags": "@smoke"
        }
    ],
    "defaultTags": "@smoke"
}